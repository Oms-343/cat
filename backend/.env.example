APP_NAME=MSME Platform API
APP_ENV=development
DATABASE_URL=sqlite:///./msme.db
JWT_SECRET=change-me-in-production-this-is-not-secure
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# WhatsApp Cloud API (optional — dry-run when token is missing or WHATSAPP_DRY_RUN=true)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DRY_RUN=true
WHATSAPP_DEFAULT_LANGUAGE=en
PLATFORM_REGISTRATION_URL=https://msme.tn.gov.in/register
ENROLL_PUBLIC_URL=http://localhost:5174
ENROLLMENT_INVITE_TTL_DAYS=30
APP_PUBLIC_URL=http://127.0.0.1:8000
WHATSAPP_WEBHOOK_VERIFY_TOKEN=msme-webhook-verify
WHATSAPP_APP_SECRET=
WHATSAPP_RESPONSE_WINDOW_DAYS=30
WHATSAPP_SEND_DELAY_SECONDS=0.08
